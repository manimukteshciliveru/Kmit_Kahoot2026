### 📄 [server/middleware/authMiddleware.js](file:///c:/Users/manim/OneDrive/Desktop/kahoot_team2026/Demo_project/server/middleware/authMiddleware.js) — JWT Guard

```javascript
const jwt = require('jsonwebtoken');

// This is a MIDDLEWARE — a checkpoint every protected route passes through
module.exports = function (req, res, next) {
    // Step 1: Get the token from the request header called 'x-auth-token'
    const token = req.header('x-auth-token');

    // Step 2: If no token is present, reject the request
    if (!token) {
        return res.status(401).json({ msg: 'No token, authorization denied' });
    }

    // Step 3: Verify the token using the secret key from .env
    try {
        const decoded = jwt.verify(token, process.env.JWT_SECRET);
        // decoded.user contains { id, role } — the user's identity

        req.user = decoded.user;
        // ^ Attach the user's identity to the request so the next handler knows who they are

        next(); // → Pass on to the actual route handler
    } catch (err) {
        // If the token is fake, expired, or tampered with:
        res.status(401).json({ msg: 'Token is not valid' });
    }
};
```

