### 📄 [server/routes/auth.js](file:///c:/Users/manim/OneDrive/Desktop/kahoot_team2026/Demo_project/server/routes/auth.js) — Login & Registration API

```javascript
// POST /api/auth/register  → DISABLED (returns 403 Forbidden)
// Why? Admin controls who can access the system. Students cannot self-register.

// POST /api/auth/login
router.post('/login', async (req, res) => {
    const { email, password } = req.body;

    // Search database by email OR username (flexible login)
    let user = await User.findOne({ $or: [{ email }, { username: email }] });

    if (!user) return res.status(400).json({ msg: 'Invalid Credentials' });

    // bcrypt.compare checks if the plain text password matches the stored hash
    const isMatch = await bcrypt.compare(password, user.password);
    if (!isMatch) return res.status(400).json({ msg: 'Invalid Credentials' });

    // Create a JWT payload containing user ID and role
    const payload = { user: { id: user.id, role: user.role } };

    // Sign the token — it expires in 1 hour
    jwt.sign(payload, process.env.JWT_SECRET, { expiresIn: '1h' }, (err, token) => {
        res.json({ token, role: user.role }); // Send token to browser
    });
});

// GET /api/auth/me  (requires auth token)
// Returns the logged-in user's full profile (without password)

// POST /api/auth/set-role  (requires auth token)
// Allows a user with role='none' to pick 'teacher', 'student', or 'admin'
// Can only be done ONCE — role cannot be changed after it's set
